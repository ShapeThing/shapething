@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix stsr: <http://ontology.shapething.com/shacl-renderer#> .
@prefix stf: <http://ontology.shapething.com/facet#> .
@prefix dbc: <http://dbpedia.org/resource/Category:> .
@prefix faker: <https://fakerjs.dev/> .

<>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;
  sh:closed true ;
  sh:nodeKind sh:IRI ;

  sh:property [
    sh:name "Given name"@en ;
    sh:group <#name> ;
    sh:path schema:givenName ;
    faker:generator faker:person.firstName ;
    sh:minCount 1;
    sh:maxCount 5;
    sh:datatype xsd:string ;
  ];
  sh:property [
    sh:name "Family name"@en ;
    sh:group <#name> ;
    faker:generator faker:person.lastName ;
    sh:path schema:familyName ;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string ;
  ];

  sh:property [
    sh:name "Gender"@en ;
    sh:in ( "Male" "Female" ) ;
    sh:maxCount 1;
    sh:path schema:gender ;
  ];
  sh:property [
    sh:name "Favorite color"@en ;
    sh:path schema:favoriteColor ;
    sh:datatype stsr:color ;
    faker:generator faker:color.rgb ;
    sh:maxCount 1;
  ];

  sh:property [
    sh:name "Is human"@en ;
    sh:path schema:isHuman ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1;
  ];

  sh:property [
    sh:name "Icon"@en ;
    sh:path schema:icon ;
    # stsr:iconifyCollections "fluent-emoji" ;
    sh:datatype <https://iconify.design> ;
  ];

  sh:property [
    sh:name "Date of birth"@en ;
    sh:path schema:birthDate ;
    sh:order 2 ;
    sh:editor dash:DatePickerEditor ;
    faker:generator faker:date.anytime ;
    sh:maxCount 1;
    sh:minCount 1;
    sh:datatype xsd:date ;
  ];

  sh:property [
    sh:name "Address"@en ;
    sh:order 4 ;
    sh:path schema:address ;
    sh:maxCount 1 ;
    sh:node <#addressShape> ;
    # sh:class schema:PostalAddress ;
    sh:nodeKind sh:BlankNode ;
  ];

.

<#name>
  sh:name "Name"@en, "Naam"@nl ;
	a sh:PropertyGroup, stsr:HorizontalPropertyGroup ;
	sh:order 1 .

<#street-and-housenumber>
	a sh:PropertyGroup, stsr:HorizontalPropertyGroup ;
	sh:order 2 .

<#world>
	a sh:PropertyGroup, stsr:HorizontalPropertyGroup ;
	sh:order 3 .


<#addressShape>
    a sh:NodeShape ;
    sh:targetClass schema:PostalAddress ;
    sh:closed true ;

  	sh:ignoredProperties (rdf:type) ;

    sh:property [
        sh:name "Street"@en ;
        sh:group <#street-and-housenumber> ;
        sh:path schema:streetAddress ;
        faker:generator faker:location.street ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:name "Postal code"@en ;
        sh:path schema:postalCode ;
        sh:group <#street-and-housenumber> ;
        faker:generator faker:location.zipCode ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:name "Locality"@en ;
        sh:group <#world> ;
        sh:path schema:addressLocality ;
        faker:generator faker:location.city ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:name "Region"@en ;
        sh:group <#world> ;
        sh:path schema:addressRegion ;
        faker:generator faker:location.state ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;

    sh:property [
        sh:name "Country"@en ;
        sh:path schema:addressCountry ;
        faker:generator faker:location.country ;
        sh:group <#world> ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .