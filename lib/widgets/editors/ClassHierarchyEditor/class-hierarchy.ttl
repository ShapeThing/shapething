@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix stsr: <http://ontology.shapething.com/shacl-renderer#> .
@prefix stf: <http://ontology.shapething.com/facet#> .

<#data>
  a schema:Recipe ;
.

<#default>
  a sh:NodeShape ;
  sh:targetClass schema:Recipe ;
  sh:closed true ;
  sh:ignoredProperties (rdf:type) ;

  sh:property [
    sh:name "Cook method"@en ;
    dash:editor stsr:ClassHierarchyEditor ;
    sh:path schema:cookMethod ;
    stsr:endpoint <./cooking-methods.ttl> ;
    sh:class <http://purl.obolibrary.org/obo/FOODON_03450002> ;
  ];
.
