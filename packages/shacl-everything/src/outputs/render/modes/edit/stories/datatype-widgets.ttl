@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;

  sh:property [
    sh:name "Is human"@en ;
    sh:path schema:isHuman ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:name "Birth date"@en ;
    sh:path schema:birthDate ;
    sh:datatype xsd:date ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:name "Household members"@en ;
    sh:path schema:householdMembers ;
    sh:datatype xsd:integer ;
    sh:minInclusive 0 ;
    sh:maxInclusive 20 ;
    sh:maxCount 1 ;
  ] ;

  sh:property [
    sh:name "Gender"@en ;
    sh:path schema:gender ;
    sh:in ("Male" "Female" "Other") ;
    sh:maxCount 1 ;
  ] .
