@prefix ex: <http://example.org/>.
@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;
    sh:not [
        sh:path ex:status ;
        sh:hasValue ex:Banned ;
    ] ;
    .


<#data>
    a schema:Person ;
    schema:givenName "Hendrik" ;
    ex:status ex:Active ;
    .
