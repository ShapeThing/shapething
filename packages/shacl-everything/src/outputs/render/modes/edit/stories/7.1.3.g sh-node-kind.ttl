@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;

    sh:property [
        sh:name "Claim"@en ;
        sh:path schema:claim ;
        sh:nodeKind sh:TripleTerm ;
        sh:minCount 1 ;
    ] ;
    .


<#data>
    a schema:Person ;
    schema:givenName "Hendrik" ;
    schema:claim <<( <#data> schema:birthDate "2000-01-01" )>> ;
    .
