@prefix ex: <http://example.org/>.
@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;

    sh:property [
        sh:name "Status"@en ;
        sh:path ex:status ;
        sh:in ( ex:Active ex:Inactive ex:Pending ) ;
    ] ;
    .


<#data>
    a schema:Person ;
    schema:givenName "Hendrik" ;
    ex:status ex:Deleted ;
    .
