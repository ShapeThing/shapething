PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>

#####################
# Data Graph Shapes #
#####################

shui:isBlankNode
    a sh:NodeShape ;
    sh:nodeKind sh:BlankNode ;
.

shui:isBoolean
    a sh:NodeShape ;
    sh:datatype xsd:boolean ;
.

shui:isDate
    a sh:NodeShape ;
    sh:datatype xsd:date ;
.

shui:isDateTime
    a sh:NodeShape ;
    sh:datatype xsd:dateTime ;
.

shui:isIRI
    a sh:NodeShape ;
    sh:nodeKind sh:IRI ;
.

shui:isIRIOrBlankNode
    a sh:NodeShape ;
    sh:or (
        [
            sh:nodeKind sh:IRI ;
        ]
        [
            sh:nodeKind sh:BlankNode ;
        ]
    ) ;
.

shui:isHTML
    a sh:NodeShape ;
    sh:datatype rdf:HTML ;
.

shui:isHTMLOrString
    a sh:NodeShape ;
    sh:or (
        [
            sh:datatype rdf:HTML ;
        ]
        [
            sh:datatype xsd:string ;
        ]
    ) ;
.

shui:isString
    a sh:NodeShape ;
    sh:datatype xsd:string ;
.

shui:isLangString
    a sh:NodeShape ;
    sh:datatype rdf:langString ;
.

shui:isAnyURI
    a sh:NodeShape ;
    sh:datatype xsd:anyURI ;
.

shui:isAnyURIOrString
    a sh:NodeShape ;
    sh:or (
        [
            sh:datatype xsd:anyURI ;
        ]
        [
            sh:datatype xsd:string ;
        ]
    ) ;
.

shui:hasImageFileExtension
    a sh:NodeShape ;
    sh:or (
        [
            sh:nodeKind sh:IRI
        ]
        [
            sh:nodeKind sh:Literal
        ]
    ) ;
    sh:pattern "\\.(jpg|jpeg|png|gif|bmp|svg|webp|avif)$" ;
    sh:flags "i" ;
.

shui:isNumericLiteral
    a sh:NodeShape ;
    sh:or (
        [
            sh:datatype xsd:decimal ;
        ]
        [
            sh:datatype xsd:integer ;
        ]
        [
            sh:datatype xsd:double ;
        ]
        [
            sh:datatype xsd:float ;
        ]
    ) ;
.

shui:isLiteral
    a sh:NodeShape ;
    sh:nodeKind sh:Literal ;
.


#######################
# Shapes Graph Shapes #
#######################

shui:isSingleLineTrue
    a sh:NodeShape ;
    sh:property [
        sh:path sh:singleLine ;
        sh:minCount 1 ;
        sh:hasValue true ;
    ] ;
.

shui:isSingleLineFalse
    a sh:NodeShape ;
    sh:property [
        sh:path sh:singleLine ;
        sh:minCount 1 ;
        sh:hasValue false ;
    ] ;
.

shui:hasInConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:in ;
        sh:minCount 1 ;
    ] ;
.

shui:hasClassConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:class ;
        sh:minCount 1 ;
    ] ;
.

shui:hasNoClassConstraint
    a sh:NodeShape ;
    sh:not shui:hasClassConstraint ;
.

shui:hasRootClassConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:rootClass ;
        sh:minCount 1 ;
    ] ;
.

shui:hasCustomDatatype
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
    ] ;
    sh:not [
        sh:property [
            sh:path sh:datatype ;
            sh:minCount 1 ;
            sh:pattern "^http://www.w3.org/2001/XMLSchema#|^http://www.w3.org/1999/02/22-rdf-syntax-ns#" ;
        ] ;
    ] ;
.

shui:hasNodeKindIRIConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:nodeKind ;
        sh:minCount 1 ;
        sh:hasValue sh:IRI ;
    ] ;
.

shui:hasNodeKindLiteralConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:nodeKind ;
        sh:minCount 1 ;
        sh:hasValue sh:Literal ;
    ] ;
.

shui:hasDatatypeStringConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
        sh:hasValue xsd:string ;
    ] ;
.

shui:hasDatatypeLangStringConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
        sh:hasValue rdf:langString ;
    ] ;
.

shui:hasDatatypeBooleanConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
        sh:hasValue xsd:boolean ;
    ] ;
.

shui:hasDatatypeDateConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
        sh:hasValue xsd:date ;
    ] ;
.

shui:hasDatatypeDateTimeConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
        sh:hasValue xsd:dateTime ;
    ] ;
.

shui:hasDatatypeHTMLConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
        sh:hasValue rdf:HTML ;
    ] ;
.

shui:hasDatatypeNumericConstraint
    a sh:NodeShape ;
    sh:property [
        sh:path sh:datatype ;
        sh:minCount 1 ;
        sh:or (
            [
                sh:hasValue xsd:decimal ;
            ]
            [
                sh:hasValue xsd:integer ;
            ]
            [
                sh:hasValue xsd:double ;
            ]
            [
                sh:hasValue xsd:float ;
            ]
        ) ;
    ] ;
.
