PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:textAreaWithLangEditorScoreMinus1
    a shui:WidgetScore ;
    shui:widget shui:TextAreaWithLangEditor ;
    shui:score -1 ;
    shui:shapesGraphShape shui:isSingleLineTrue ;
.

shui:textAreaWithLangEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:TextAreaWithLangEditor ;
    shui:score 40 ;
    shui:shapesGraphShape shui:prefersTextAreaWithLangEditor ;
.

shui:textAreaWithLangEditorScore30
    a shui:WidgetScore ;
    shui:widget shui:TextAreaWithLangEditor ;
    shui:score 30 ;
    shui:dataGraphShape shui:isLangString ;
    shui:shapesGraphShape shui:isSingleLineFalse ;
.

shui:textAreaWithLangEditorScore20
    a shui:WidgetScore ;
    shui:widget shui:TextAreaWithLangEditor ;
    shui:score 20 ;
    shui:dataGraphShape shui:isLangString ;
.

shui:textAreaWithLangEditorScore5
    a shui:WidgetScore ;
    shui:widget shui:TextAreaWithLangEditor ;
    shui:score 5 ;
    shui:shapesGraphShape shui:hasDatatypeLangStringConstraint ;
.

shui:textAreaWithLangEditorScore0
    a shui:WidgetScore ;
    shui:widget shui:TextAreaWithLangEditor ;
    shui:score 0 ;
    shui:shapesGraphShape shui:hasDatatypeStringConstraint ;
.

shui:prefersTextAreaWithLangEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:TextAreaWithLangEditor ;
    ] ;
.
