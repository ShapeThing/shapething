PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:textFieldWithLangEditorScoreMinus1
    a shui:WidgetScore ;
    shui:widget shui:TextFieldWithLangEditor ;
    shui:score -1 ;
    shui:shapesGraphShape shui:isSingleLineFalse ;
.

shui:textFieldWithLangEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:TextFieldWithLangEditor ;
    shui:score 40 ;
    shui:shapesGraphShape shui:prefersTextFieldWithLangEditor ;
.

shui:textFieldWithLangEditorScore30
    a shui:WidgetScore ;
    shui:widget shui:TextFieldWithLangEditor ;
    shui:score 30 ;
    shui:dataGraphShape shui:isLangString ;
.

shui:textFieldWithLangEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:TextFieldWithLangEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasDatatypeLangStringConstraint ;
.

shui:textFieldWithLangEditorScore1
    a shui:WidgetScore ;
    shui:widget shui:TextFieldWithLangEditor ;
    shui:score 1 ;
    shui:shapesGraphShape shui:hasDatatypeStringConstraint ;
.

shui:prefersTextFieldWithLangEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:TextFieldWithLangEditor ;
    ] ;
.
