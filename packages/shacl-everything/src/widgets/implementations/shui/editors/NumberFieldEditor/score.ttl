PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:numberFieldEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:NumberFieldEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isNumericLiteral ;
    shui:shapesGraphShape shui:prefersNumberFieldEditor ;
.

shui:numberFieldEditorScore20
    a shui:WidgetScore ;
    shui:widget shui:NumberFieldEditor ;
    shui:score 20 ;
    shui:dataGraphShape shui:isNumericLiteral ;
.

shui:numberFieldEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:NumberFieldEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasDatatypeNumericConstraint ;
.

shui:prefersNumberFieldEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:NumberFieldEditor ;
    ] ;
.
