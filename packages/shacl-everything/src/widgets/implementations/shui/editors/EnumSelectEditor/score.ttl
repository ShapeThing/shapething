PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:enumSelectEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:EnumSelectEditor ;
    shui:score 40 ;
    shui:shapesGraphShape shui:prefersEnumSelectEditor, shui:hasInConstraint ;
.

shui:enumSelectEditorScore30
    a shui:WidgetScore ;
    shui:widget shui:EnumSelectEditor ;
    shui:score 30 ;
    shui:shapesGraphShape shui:hasInConstraint ;
.

shui:prefersEnumSelectEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:EnumSelectEditor ;
    ] ;
.
