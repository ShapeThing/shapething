PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:booleanEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:BooleanEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isBoolean ;
    shui:shapesGraphShape shui:prefersBooleanEditor ;
.

shui:booleanEditorScore20
    a shui:WidgetScore ;
    shui:widget shui:BooleanEditor ;
    shui:score 20 ;
    shui:dataGraphShape shui:isBoolean ;
.

shui:booleanEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:BooleanEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasDatatypeBooleanConstraint ;
.

shui:prefersBooleanEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:BooleanEditor ;
    ] ;
.
