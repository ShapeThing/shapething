PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:iriEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:IRIEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isIRI ;
    shui:shapesGraphShape shui:prefersIRIEditor ;
.

shui:iriEditorScore20
    a shui:WidgetScore ;
    shui:widget shui:IRIEditor ;
    shui:score 20 ;
    shui:dataGraphShape shui:isIRI ;
    shui:shapesGraphShape shui:hasNodeKindIRIConstraint, shui:hasNoClassConstraint ;
.

shui:iriEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:IRIEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasNodeKindIRIConstraint, shui:hasNoClassConstraint ;
.

shui:iriEditorScore0
    a shui:WidgetScore ;
    shui:widget shui:IRIEditor ;
    shui:score 0 ;
    shui:dataGraphShape shui:isIRI ;
.

shui:prefersIRIEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:IRIEditor ;
    ] ;
.
