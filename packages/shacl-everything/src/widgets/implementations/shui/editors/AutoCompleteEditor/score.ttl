PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:autoCompleteEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:AutoCompleteEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isIRI ;
    shui:shapesGraphShape shui:prefersAutoCompleteEditor, shui:hasClassConstraint ;
.

shui:autoCompleteEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:AutoCompleteEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasNodeKindIRIConstraint, shui:hasClassConstraint ;
.

shui:prefersAutoCompleteEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:AutoCompleteEditor ;
    ] ;
.
