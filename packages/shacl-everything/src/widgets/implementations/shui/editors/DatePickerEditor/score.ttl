PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:datePickerEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:DatePickerEditor ;
    shui:score 20 ;
    shui:dataGraphShape shui:isDate ;
    shui:shapesGraphShape shui:prefersDatePickerEditor ;
.

shui:datePickerEditorScore20
    a shui:WidgetScore ;
    shui:widget shui:DatePickerEditor ;
    shui:score 30 ;
    shui:dataGraphShape shui:isDate ;
.

shui:datePickerEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:DatePickerEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasDatatypeDateConstraint ;
.

shui:prefersDatePickerEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:DatePickerEditor ;
    ] ;
.
