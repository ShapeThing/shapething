PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:detailsEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:DetailsEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isIRIOrBlankNode ;
    shui:shapesGraphShape shui:prefersDetailsEditor ;
.

shui:detailsEditorScore0
    a shui:WidgetScore ;
    shui:widget shui:DetailsEditor ;
    shui:score 0 ;
    shui:dataGraphShape shui:isIRIOrBlankNode ;
.

shui:prefersDetailsEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:DetailsEditor ;
    ] ;
.
