PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>

shui:instancesSelectEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:InstancesSelectEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isIRI ;
    shui:shapesGraphShape shui:prefersInstancesSelectEditor, shui:hasClassConstraint ;
.

shui:instancesSelectEditorScore0
    a shui:WidgetScore ;
    shui:widget shui:InstancesSelectEditor ;
    shui:score 0 ;
    shui:shapesGraphShape shui:hasClassConstraint ;
.

shui:prefersInstancesSelectEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:InstancesSelectEditor ;
    ] ;
.
