PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:subClassEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:SubClassEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isIRI ;
    shui:shapesGraphShape shui:prefersSubClassEditor, shui:hasRootClassConstraint ;
.

shui:prefersSubClassEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:SubClassEditor ;
    ] ;
.
