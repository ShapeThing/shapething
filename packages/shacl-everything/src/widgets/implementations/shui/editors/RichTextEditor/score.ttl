PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:richTextEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:RichTextEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isHTML ;
    shui:shapesGraphShape shui:prefersRichTextEditor ;
.

shui:richTextEditorScore20
    a shui:WidgetScore ;
    shui:widget shui:RichTextEditor ;
    shui:score 20 ;
    shui:dataGraphShape shui:isHTML ;
.

shui:richTextEditorScore10
    a shui:WidgetScore ;
    shui:widget shui:RichTextEditor ;
    shui:score 10 ;
    shui:shapesGraphShape shui:hasDatatypeHTMLConstraint ;
.

shui:prefersRichTextEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:RichTextEditor ;
    ] ;
.
