PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:blankNodeEditorScore40
    a shui:WidgetScore ;
    shui:widget shui:BlankNodeEditor ;
    shui:score 40 ;
    shui:dataGraphShape shui:isBlankNode ;
    shui:shapesGraphShape shui:prefersBlankNodeEditor ;
.

shui:blankNodeEditorScore1
    a shui:WidgetScore ;
    shui:widget shui:BlankNodeEditor ;
    shui:score 1 ;
    shui:dataGraphShape shui:isBlankNode ;
.

shui:prefersBlankNodeEditor
    a sh:NodeShape ;
    sh:property [
        sh:path shui:editor ;
        sh:hasValue shui:BlankNodeEditor ;
    ] ;
.
