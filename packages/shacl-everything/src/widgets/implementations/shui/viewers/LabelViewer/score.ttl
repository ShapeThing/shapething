PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:labelViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:LabelViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersLabelViewer ;
.

shui:labelViewerScore10
    a shui:WidgetScore ;
    shui:widget shui:LabelViewer ;
    shui:score 10 ;
    shui:dataGraphShape shui:isIRI ;
.

shui:prefersLabelViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:LabelViewer ;
    ] ;
.
