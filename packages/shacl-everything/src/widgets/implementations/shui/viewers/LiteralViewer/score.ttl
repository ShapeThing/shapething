PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:literalViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:LiteralViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersLiteralViewer ;
.

shui:literalViewerScore1
    a shui:WidgetScore ;
    shui:widget shui:LiteralViewer ;
    shui:score 1 ;
    shui:dataGraphShape shui:isLiteral ;
.

shui:prefersLiteralViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:LiteralViewer ;
    ] ;
.
