PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:imageViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:ImageViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersImageViewer ;
.

shui:imageViewerScore20
    a shui:WidgetScore ;
    shui:widget shui:ImageViewer ;
    shui:score 20 ;
    shui:dataGraphShape shui:hasImageFileExtension ;
.

shui:prefersImageViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:ImageViewer ;
    ] ;
.
