PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:htmlViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:HTMLViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersHTMLViewer ;
.

shui:htmlViewerScore20
    a shui:WidgetScore ;
    shui:widget shui:HTMLViewer ;
    shui:score 20 ;
    shui:dataGraphShape shui:isHTML ;
.

shui:prefersHTMLViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:HTMLViewer ;
    ] ;
.
