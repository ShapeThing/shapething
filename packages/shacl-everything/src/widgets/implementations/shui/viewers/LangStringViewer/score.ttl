PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:langStringViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:LangStringViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersLangStringViewer ;
.

shui:langStringViewerScore20
    a shui:WidgetScore ;
    shui:widget shui:LangStringViewer ;
    shui:score 20 ;
    shui:dataGraphShape shui:isLangString ;
.

shui:prefersLangStringViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:LangStringViewer ;
    ] ;
.
