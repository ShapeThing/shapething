PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:detailsViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:DetailsViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersDetailsViewer ;
.

shui:detailsViewerScore0
    a shui:WidgetScore ;
    shui:widget shui:DetailsViewer ;
    shui:score 0 ;
    shui:dataGraphShape shui:isIRIOrBlankNode ;
.

shui:prefersDetailsViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:DetailsViewer ;
    ] ;
.
