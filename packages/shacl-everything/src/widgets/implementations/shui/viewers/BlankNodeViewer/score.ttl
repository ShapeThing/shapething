PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:blankNodeViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:BlankNodeViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersBlankNodeViewer ;
.

shui:blankNodeViewerScore1
    a shui:WidgetScore ;
    shui:widget shui:BlankNodeViewer ;
    shui:score 1 ;
    shui:dataGraphShape shui:isBlankNode ;
.

shui:prefersBlankNodeViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:BlankNodeViewer ;
    ] ;
.
