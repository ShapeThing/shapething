PREFIX sh: <http://www.w3.org/ns/shacl#>
PREFIX shui: <http://www.w3.org/ns/shacl-ui/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

shui:hyperlinkViewerScore30
    a shui:WidgetScore ;
    shui:widget shui:HyperlinkViewer ;
    shui:score 30 ;
    shui:shapesGraphShape shui:prefersHyperlinkViewer ;
.

shui:hyperlinkViewerScore20
    a shui:WidgetScore ;
    shui:widget shui:HyperlinkViewer ;
    shui:score 20 ;
    shui:dataGraphShape shui:isAnyURI ;
.

shui:hyperlinkViewerScore0
    a shui:WidgetScore ;
    shui:widget shui:HyperlinkViewer ;
    shui:score 0 ;
    shui:dataGraphShape shui:isString ;
.

shui:prefersHyperlinkViewer
    a sh:NodeShape ;
    sh:property [
        sh:path shui:viewer ;
        sh:hasValue shui:HyperlinkViewer ;
    ] ;
.
