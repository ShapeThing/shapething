@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;

    sh:property [
        sh:name "Website"@en ;
        sh:path schema:url ;
        sh:nodeKind sh:IRI ;
        sh:minCount 1 ;
    ] ;
    .


<#data>
    a schema:Person ;
    schema:givenName "Hendrik" ;
    schema:url <https://example.org/hendrik> ;
    .
