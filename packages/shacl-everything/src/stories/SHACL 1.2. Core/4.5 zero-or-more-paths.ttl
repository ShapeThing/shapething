@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;
    sh:property [
        sh:name "Self and ancestors"@en ;
        sh:path [
            sh:zeroOrMorePath schema:parent ;
        ] ;
    ] ;
    .


<#data>
    a schema:Person ;
    foaf:name "Hendrik" ;
    schema:parent <#dad> ;
    .

<#dad>
    a schema:Person ;
    foaf:name "John" ;
    schema:parent <#grandpa> ;
    .

<#grandpa>
    a schema:Person ;
    foaf:name "Peter" ;
    .
