@prefix ex: <http://example.org/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;

    sh:property [
        sh:name "Age"@en ;
        sh:path ex:age ;
        sh:datatype xsd:integer ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:reifierShape [
            sh:property [
                sh:path ex:date ;
                sh:datatype xsd:date ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ] ;
            sh:property [
                sh:path ex:author ;
                sh:nodeKind sh:IRI ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ] ;
        ] ;
        sh:reificationRequired true ;
    ] ;
    .


<#data>
    a schema:Person ;
    schema:givenName "Hendrik" ;
    ex:age 23 {|
        ex:date "2026-01-01"^^xsd:date ;
        ex:author ex:Claire
    |} ;
    .
