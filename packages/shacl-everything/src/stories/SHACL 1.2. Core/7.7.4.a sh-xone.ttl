@prefix ex: <http://example.org/>.
@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;
    sh:xone (
        [
            sh:property [
                sh:path ex:fullName ;
                sh:minCount 1 ;
            ] ;
        ]
        [
            sh:property [
                sh:path schema:givenName ;
                sh:minCount 1 ;
            ] ;
            sh:property [
                sh:path ex:familyName ;
                sh:minCount 1 ;
            ] ;
        ]
    ) ;
    .


<#data>
    a schema:Person ;
    schema:givenName "Hendrik" ;
    ex:familyName "Jansen" ;
    .
