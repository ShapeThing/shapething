@prefix schema: <http://schema.org/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

<#shape>
    a sh:NodeShape ;
    sh:targetClass schema:Person ;

    sh:property [
        sh:name "Nickname"@en ;
        sh:path schema:alternateName ;
        sh:maxCount 3 ;
    ] ;
    .


<#data>
    a schema:Person ;
    schema:givenName "Hendrik" ;
    schema:alternateName "Hank", "Hendrikus" ;
    .
