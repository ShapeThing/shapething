@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix stsr: <http://ontology.shapething.com/shacl-renderer#> .
@prefix stf: <http://ontology.shapething.com/facet#> .
@prefix dbc: <http://dbpedia.org/resource/Category:> .
@prefix wdt: <http://www.wikidata.org/prop/direct/> .
@prefix dcterms: <http://purl.org/dc/terms/> .

<#example1>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;
  sh:closed true ;

  sh:property [
    sh:name "Knows"@en ;
    sh:nodeKind sh:IRI ;
    sh:path schema:knows ;
  ];
.

<#data1>
    schema:knows 
    <http://dbpedia.org/resource/Søren_Kierkegaard>,
    <https://pleiades.stoa.org/places/570085/>,
    <https://ruben.verborgh.org/profile/#me>,
    <https://schema.org/birthDate>,
    <https://openlibrary.org/works/OL1968368W>,
    <https://ruben.verborgh.org/> .


<#example2>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;
  sh:closed true ;

  sh:property [
    sh:name "Knows"@en ;
    stsr:endpoint <https://dbpedia.org/sparql>;
    sh:description "Uses Dbpedia" ;
    sh:class <http://dbpedia.org/ontology/FloweringPlant> ;
    sh:path schema:knows ;
  ];
.

<#data2>
    schema:knows 
    <http://dbpedia.org/resource/Iris_versicolor>
 .


<#example3>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;

  sh:property [
    sh:path rdf:type ;
    sh:hasValue schema:Person ;
  ];

  sh:property [
    sh:name "Reference"@en ;
    sh:path schema:ref ;
    sh:description "Search for Jan" ;
    stsr:endpoint <urn:store:lorem>;
    sh:node [
      sh:property [
        sh:path schema:name ;
        sh:minCount 1;
        stsr:purpose stsr:label ;
      ] ;
      sh:property [
        sh:path rdf:type ;
        sh:hasValue schema:Person ;
      ] ;

      sh:property [
        sh:path schema:image ;
        stsr:purpose stsr:image ;
      ] ;
    ]
  ];

.


<#example4>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;

  sh:property [
    sh:name "Reference"@en ;
    sh:path schema:ref ;
    sh:description "Search for Jan" ;
    sh:message "This error is because the external triple still need to be added to the validation store." ;
    # TODO these triples also need to be added to validation.
    stsr:endpoint <urn:store:lorem>;
    sh:class schema:Person ;
  ];

.

<#example5>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;


  sh:property [
    sh:name "Knows"@en ;
    sh:description """Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras sem lacus, mollis eget velit vel, tempus lobortis ex.""" ;
    sh:path schema:knows ;
    sh:maxCount 4 ;
    stsr:endpoint <https://dbpedia.org/sparql>;
    sh:message "You must select a philosopher of religion" ;
    sh:node [
      sh:property [
        sh:path rdfs:label ;
        sh:minCount 1;
        stsr:purpose stsr:label ;
        sh:languageIn ( "en" ) ;
      ] ;

      sh:property [
        sh:path <http://dbpedia.org/ontology/thumbnail> ;
        stsr:purpose stsr:image ;
      ] ;

      sh:property [
        sh:path <http://purl.org/dc/terms/subject> ;
        sh:hasValue dbc:Philosophers_of_religion ;
      ] ;
    ]
  ] ;

.

<#example6>
  a sh:NodeShape ;
  sh:targetClass schema:Person ;


  sh:property [
    sh:name "Knows"@en ;
    sh:description """Lorem ipsum dolor sit amet, consectetur adipiscing elit. Cras sem lacus, mollis eget velit vel, tempus lobortis ex.""" ;
    sh:path schema:knows ;
    sh:maxCount 4 ;
    sh:node [
      sh:property [
        sh:path schema:name ;
        sh:minCount 1;
        stsr:purpose stsr:label ;
        sh:languageIn ( "en" ) ;
      ] ;
    ]
  ] ;

.

<#data6> a schema:Person .

<#john>
  a schema:Person ;
  schema:name "John Doe"@en ;
.


<#knowsFilter>
      sh:property [
        sh:path [ sh:alternativePath ( rdfs:label schema:name dcterms:title ) ] ;
        sh:minCount 1;
        stsr:purpose stsr:label ;
      ] ;

      sh:property [
        stsr:purpose stsr:image ;
        sh:path [ sh:alternativePath ( <http://dbpedia.org/ontology/thumbnail> schema:image <http://xmlns.com/foaf/0.1/img> ) ] ;
      ] ;
.