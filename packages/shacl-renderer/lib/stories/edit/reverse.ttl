@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix stsr: <http://ontology.shapething.com/shacl-renderer#> .
@prefix faker: <https://fakerjs.dev/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<>
  a sh:NodeShape, stsr:Shape ;
  sh:targetClass schema:Person ;
  sh:closed true ;
  sh:name "Person" ;

  sh:property [
    sh:path rdf:type ;
    sh:hasValue schema:Person ;
  ];

  sh:property [
    sh:name "Name" ;
    sh:path schema:name ;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string ;
  ];

  sh:property [
    sh:name "Given name" ;
    sh:path schema:givenName ;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string ;
  ];

  sh:property [
    sh:name "Family name" ;
    sh:path schema:familyName ;
    sh:minCount 1;
    sh:maxCount 1;
    sh:datatype xsd:string ;
  ];

 sh:property [
    sh:name "Parents" ;
	  sh:nodeKind sh:IRI ;
    sh:minCount 0 ;
    sh:message "A person can have zero or more parents." ;
    sh:path [ sh:inversePath schema:child ] ;
  ];
.

<#john>
    schema:name "John Doe" ;
    schema:givenName "John" ;
    schema:familyName "Doe" ;
    .

<#father>
    a schema:Person ;
    schema:child <#john> ;
    schema:name "Richard Doe" ;
    schema:givenName "Richard" ;
    schema:familyName "Doe" ;
    .
<#mother>   
    a schema:Person ;
    schema:child <#john> ;
    schema:name "Jane Doe" ;
    schema:givenName "Jane" ;
    schema:familyName "Doe" ;
    .


<#mother2>   
    a schema:Person ;
    schema:name "Astrid Doe" ;
    schema:givenName "Astrid" ;
    schema:familyName "Doe" ;
    .