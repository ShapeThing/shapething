@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://nlbegrip.nl/def/skosapnl#Concept> a sh:NodeShape ;
  rdfs:comment "An idea or notion; a unit of thought."@en, "Een abstract idee of notie."@nl ;
  rdfs:label "Begrip"@nl, "Concept"@en ;
  sh:property <http://nlbegrip.nl/def/skosapnl#Concept-altLabel>, <http://nlbegrip.nl/def/skosapnl#Concept-broader>, <http://nlbegrip.nl/def/skosapnl#Concept-broaderGeneric>, <http://nlbegrip.nl/def/skosapnl#Concept-broaderInstantial>, <http://nlbegrip.nl/def/skosapnl#Concept-broaderPartitive>, <http://nlbegrip.nl/def/skosapnl#Concept-broadMatch>, <http://nlbegrip.nl/def/skosapnl#Concept-changeNote>, <http://nlbegrip.nl/def/skosapnl#Concept-closeMatch>, <http://nlbegrip.nl/def/skosapnl#Concept-comment>, <http://nlbegrip.nl/def/skosapnl#Concept-definition>, <http://nlbegrip.nl/def/skosapnl#Concept-editorialNote>, <http://nlbegrip.nl/def/skosapnl#Concept-exactMatch>, <http://nlbegrip.nl/def/skosapnl#Concept-example>, <http://nlbegrip.nl/def/skosapnl#Concept-hiddenLabel>, <http://nlbegrip.nl/def/skosapnl#Concept-historyNote>, <http://nlbegrip.nl/def/skosapnl#Concept-inScheme>, <http://nlbegrip.nl/def/skosapnl#Concept-label>, <http://nlbegrip.nl/def/skosapnl#Concept-narrower>, <http://nlbegrip.nl/def/skosapnl#Concept-narrowerGeneric>, <http://nlbegrip.nl/def/skosapnl#Concept-narrowerInstantial>, <http://nlbegrip.nl/def/skosapnl#Concept-narrowerPartitive>, <http://nlbegrip.nl/def/skosapnl#Concept-narrowMatch>, <http://nlbegrip.nl/def/skosapnl#Concept-notation>, <http://nlbegrip.nl/def/skosapnl#Concept-prefLabel>, <http://nlbegrip.nl/def/skosapnl#Concept-related>, <http://nlbegrip.nl/def/skosapnl#Concept-relatedMatch>, <http://nlbegrip.nl/def/skosapnl#Concept-scopeNote>, <http://nlbegrip.nl/def/skosapnl#Concept-source>, <http://nlbegrip.nl/def/skosapnl#Concept-topConceptOf> ;
  sh:severity sh:Warning ;
  sh:sparql <http://nlbegrip.nl/def/skosapnl#OrphanConcept>, <http://nlbegrip.nl/def/skosapnl#TopConceptHavingBroader>, <http://nlbegrip.nl/def/skosapnl#UnambiguousNotations>, <http://nlbegrip.nl/def/skosapnl#UniquePreflabelWithinConceptScheme> ;
  sh:targetClass skos:Concept .

<http://nlbegrip.nl/def/skosapnl#Concept-altLabel> a sh:PropertyShape ;
  rdfs:label "alternatieve term"@nl ;
  sh:datatype rdf:langString ;
  sh:description "An alternative lexical label for a resource."@en, "Een alternatieve term voor een begrip is een term die gebruikt kan worden als alternatief voor de voorkeursterm van dit begrip, maar niet de voorkeur heeft."@nl ;
  sh:disjoint skos:hiddenLabel, skos:prefLabel ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "alternatieve term"@nl, "alternative name"@en ;
  sh:nodeKind sh:Literal ;
  sh:order 1 ;
  sh:path skos:altLabel ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-broader> a sh:PropertyShape ;
  rdfs:label "heeft bovenliggend begrip"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een bovenliggend begrip in de hierarchie."@nl, "Relates a concept to a concept that is more general in meaning."@en ;
  sh:disjoint skos:related ;
  sh:group <http://nlbegrip.nl/def/skosapnl#SemanticRelationPropertyGroup> ;
  sh:name "has broader"@en, "heeft bovenliggend begrip"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 20 ;
  sh:path skos:broader ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-broaderGeneric> a sh:PropertyShape ;
  rdfs:label "Is specialisatie van"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een meer generiek begrip."@nl, "Used to state the immediate (direct or one-step) class - generalized class relationship."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#Iso-thesRelationships> ;
  sh:name "broader term (generic)"@en, "is specialisatie van"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 51 ;
  sh:path <http://purl.org/iso25964/skos-thes#broaderGeneric> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-broaderInstantial> a sh:PropertyShape ;
  rdfs:label "is exemplaar van"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip, een exemplaar, aan een ander begrip, de categorie, waartoe eerstgenoemde begrip behoort."@nl, "Used to state the immediate (direct or one-step) instance - class relationship."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#Iso-thesRelationships> ;
  sh:name "broader term (instantial)"@en, "is exemplaar van"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 55 ;
  sh:path <http://purl.org/iso25964/skos-thes#broaderInstantial> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-broaderPartitive> a sh:PropertyShape ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een meer omvattend begrip."@nl, "Relates a concept to a more including concept."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#Iso-thesRelationships> ;
  sh:name "broader term (partitive)"@en, "is onderdeel van"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 53 ;
  sh:path <http://purl.org/iso25964/skos-thes#broaderPartitive> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-broadMatch> a sh:PropertyShape ;
  rdfs:label "heeft overeenkomstig bovenliggend"@nl ;
  sh:class skos:Concept ;
  sh:description "skos:broadMatch is used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en, "Used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en ;
  sh:disjoint skos:closeMatch, skos:exactMatch, skos:narrowMatch, skos:relatedMatch ;
  sh:group <http://nlbegrip.nl/def/skosapnl#MatchingRelationshipsPropertyGroup> ;
  sh:name "has broader match"@en, "heeft overeenkomstig bovenliggend"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 40 ;
  sh:path skos:broadMatch ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-changeNote> a sh:PropertyShape ;
  rdfs:label "wijzigingsnotitie"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A note about a modification to a concept."@en, "Notitie over een wijziging aan het concept"@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#NotesPropertyGroup> ;
  sh:name "change note"@en, "wijzigingsnotitie"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 31 ;
  sh:path skos:changeNote ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-closeMatch> a sh:PropertyShape ;
  rdfs:label "is vrijwel overeenkomstig"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert twee begrippen uit verschillende begrippenkaders die zoveel op elkaar lijken dat ze in sommige toepassingen door elkaar kunnen worden gebruikt voor het ophalen van informatie. De betekenis van deze begrippen is ongeveer gelijk aan elkaar."@nl, "Relates two concepts that are sufficiently similar that they can be used interchangeably in some information retrieval applications."@en ;
  sh:disjoint skos:exactMatch, skos:narrowMatch, skos:relatedMatch ;
  sh:group <http://nlbegrip.nl/def/skosapnl#MatchingRelationshipsPropertyGroup> ;
  sh:name "has close match"@en, "is vrijwel overeenkomstig"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 42 ;
  sh:path skos:closeMatch .

<http://nlbegrip.nl/def/skosapnl#Concept-comment> a sh:PropertyShape ;
  rdfs:label "comment"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A description of the subject resource in simple language, at language level B1, which can be understood without further context."@en, "Een beschrijving van iets in eenvoudige taal, op taalniveau B1, die zonder verdere context begrepen kan worden."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "comment"@en, "uitleg"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 5 ;
  sh:path rdfs:comment ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-definition> a sh:PropertyShape ;
  rdfs:label "definitie"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A statement or formal explanation of the meaning of a concept."@en, "Een definitie van een begrip is een tekstuele beschrijving van de betekenis van dit begrip waarmee het begrip kan worden onderscheiden van andere begrippen."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#DefinitionPropertyGroup> ;
  sh:minCount 1 ;
  sh:name "definitie"@nl, "definition"@en ;
  sh:nodeKind sh:Literal ;
  sh:order 10 ;
  sh:path skos:definition ;
  sh:severity sh:Violation .

<http://nlbegrip.nl/def/skosapnl#Concept-editorialNote> a sh:PropertyShape ;
  rdfs:label "redactionele notitie"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A note for an editor, translator or maintainer of the vocabulary."@en, "Een notitie voor de redacteur, vertaler of beheerder van het begrippenkader."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#NotesPropertyGroup> ;
  sh:name "editorial note"@en, "redactionele notitie"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 32 ;
  sh:path skos:editorialNote ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-exactMatch> a sh:PropertyShape ;
  rdfs:label "is exact overeenkomstig"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een overeenkomstig begrip uit een ander begrippenkader, waarbij de betekenis van deze begrippen bij uiteenlopende toepassingen gelijk aan elkaar kan worden verondersteld."@nl, "Used to link two concepts, indicating a high degree of confidence that the concepts can be used interchangeably across a wide range of information retrieval applications. Exact match is a transitive property."@en ;
  sh:disjoint skos:broadMatch, skos:closeMatch, skos:narrowMatch, skos:relatedMatch ;
  sh:group <http://nlbegrip.nl/def/skosapnl#MatchingRelationshipsPropertyGroup> ;
  sh:name "has exact match"@en, "is exact overeenkomstig"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 43 ;
  sh:path skos:exactMatch ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-example> a sh:PropertyShape ;
  rdfs:label "voorbeeld"@nl ;
  sh:description "An example of the use of a concept."@en, "Een voorbeeld van het gebruik van het concept."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#NotesPropertyGroup> ;
  sh:name "example"@en, "voorbeeld"@nl ;
  sh:nodeKind sh:Literal ;
  sh:or ([
    sh:datatype rdf:langString
  ] [
    sh:datatype xsd:string
  ]) ;
  sh:order 35 ;
  sh:path skos:example ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-hiddenLabel> a sh:PropertyShape ;
  rdfs:label "zoekterm"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A hidden label is a lexical label for a resource that should be hidden when generating visual displays of the resource, but should still be accessible to free text search operations."@en, "Een zoekterm is een naam waarmee de vindbaarheid van een resource wordt vergroot, maar verder verborgen blijft."@nl ;
  sh:disjoint skos:altLabel, skos:prefLabel ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "hidden label"@en, "zoekterm"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 2 ;
  sh:path skos:hiddenLabel ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-historyNote> a sh:PropertyShape ;
  rdfs:label "historie notitie"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A note about the past state/use/meaning of a concept."@en, "Notitie over de voormalige status/gebruik/betekenis van het begrip"@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#NotesPropertyGroup> ;
  sh:name "historie notitie"@nl, "history note"@en ;
  sh:nodeKind sh:Literal ;
  sh:order 33 ;
  sh:path skos:historyNote ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-inScheme> a sh:PropertyShape ;
  sh:class skos:ConceptScheme ;
  sh:description "Relateert een begrip aan een begrippenkader waarin het is opgenomen."@nl, "Relates a resource (for example a concept) to a concept scheme in which it is included."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "in kader"@nl, "in scheme"@en ;
  sh:nodeKind sh:IRI ;
  sh:order 6 ;
  sh:path skos:inScheme ;
  sh:severity sh:Violation .

<http://nlbegrip.nl/def/skosapnl#Concept-label> a sh:PropertyShape ;
  rdfs:label "naam"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A word or phrase used to label the concept."@en, "Een naam is een mensleesbare term ter aanduiding van het begrip."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "label"@en, "naam"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 4 ;
  sh:path rdfs:label ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-narrower> a sh:PropertyShape ;
  rdfs:label "heeft onderliggend begrip"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een onderliggend begrip in de hierarchie."@nl, "Relates a concept to a concept that is more specific in meaning."@en ;
  sh:disjoint skos:related ;
  sh:group <http://nlbegrip.nl/def/skosapnl#SemanticRelationPropertyGroup> ;
  sh:name "has narrower"@en, "heeft onderliggend begrip"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 21 ;
  sh:path skos:narrower ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-narrowerGeneric> a sh:PropertyShape ;
  rdfs:label "Is generalisatie van"@nl ;
  sh:class skos:Concept ;
  sh:description "Related a concept to a more specific concept"@en, "Relateert een begrip aan een meer specifieker begrip"@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#Iso-thesRelationships> ;
  sh:name "is generalisatie van"@nl, "is generalisation of"@en ;
  sh:nodeKind sh:IRI ;
  sh:order 52 ;
  sh:path <http://purl.org/iso25964/skos-thes#narrowerGeneric> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-narrowerInstantial> a sh:PropertyShape ;
  rdfs:label "is categorie van"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip, de categorie, aan een begrip dat exemplarisch is voor eerstgenoemde begrip."@nl, "Used to state the immediate (direct or one-step) class - instance relationship."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#Iso-thesRelationships> ;
  sh:name "is categorie van"@nl, "narrower term (instantial)"@en ;
  sh:nodeKind sh:IRI ;
  sh:order 56 ;
  sh:path <http://purl.org/iso25964/skos-thes#narrowerInstantial> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-narrowerPartitive> a sh:PropertyShape ;
  rdfs:label "omvat"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een minder omvattend begrip."@nl, "Relates a concept to a less including concept."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#Iso-thesRelationships> ;
  sh:name "narrower term (partitive)"@en, "omvat"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 54 ;
  sh:path <http://purl.org/iso25964/skos-thes#narrowerPartitive> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-narrowMatch> a sh:PropertyShape ;
  rdfs:label "heeft overeenkomstig onderliggend"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een specifieker begrip uit een ander begrippenkader."@nl, "Used to state a hierarchical mapping link between two conceptual resources in different concept schemes."@en ;
  sh:disjoint skos:broadMatch, skos:closeMatch, skos:exactMatch, skos:relatedMatch ;
  sh:group <http://nlbegrip.nl/def/skosapnl#MatchingRelationshipsPropertyGroup> ;
  sh:name "has narrower match"@en, "heeft overeenkomstig onderliggend"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 41 ;
  sh:path skos:narrowMatch ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-notation> a sh:PropertyShape ;
  rdfs:label "Code"@nl ;
  sh:description "A notation, also known as classification code, is a string of characters used to uniquely identify a concept within the scope of a given concept scheme."@en, "Een code voor een begrip is een tekenreeks ter aanduiding van precies één begrip uit een begrippenkader."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "code"@nl, "notation"@en ;
  sh:order 3 ;
  sh:path skos:notation ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-prefLabel> rdfs:label "Voorkeursterm"@nl ;
  sh:datatype rdf:langString ;
  sh:description "Een naam die in een specifieke taal de geprefereerde lexicale naam is."@nl, "The preferred lexical label for a resource, in a given language."@en ;
  sh:disjoint skos:altLabel ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:minCount 1 ;
  sh:name "preferred label"@en, "voorkeursterm"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 0 ;
  sh:path skos:prefLabel ;
  sh:severity sh:Warning ;
  sh:uniqueLang true .

<http://nlbegrip.nl/def/skosapnl#Concept-related> a sh:PropertyShape ;
  rdfs:label "is gerelateerd aan"@nl ;
  sh:class skos:Concept ;
  sh:description "Een concept met een associatieve semantische relatie"@nl, "Relates a concept to a concept with which there is an associative semantic relationship."@en ;
  sh:disjoint skos:broader, skos:narrower ;
  sh:group <http://nlbegrip.nl/def/skosapnl#SemanticRelationPropertyGroup> ;
  sh:name "has related"@en, "is gerelateerd aan"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 22 ;
  sh:path skos:related ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-relatedMatch> a sh:PropertyShape ;
  rdfs:label "is overeenkomstig verwant"@nl ;
  sh:class skos:Concept ;
  sh:description "Relateert een begrip aan een verwant begrip uit een ander begrippenkader."@nl, "Used to state an associative mapping link between two conceptual resources in different concept schemes."@en ;
  sh:disjoint skos:broadMatch, skos:closeMatch, skos:exactMatch, skos:narrowMatch ;
  sh:group <http://nlbegrip.nl/def/skosapnl#MatchingRelationshipsPropertyGroup> ;
  sh:name "has related match"@en, "is overeenkomstig verwant"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 44 ;
  sh:path skos:relatedMatch ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-scopeNote> a sh:PropertyShape ;
  rdfs:label "toelichting"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A note that helps to clarify the meaning and/or the use of a concept."@en, "Een notitie die meer duidelijkheid geeft over de betekenis of gebruik van een begrip."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#NotesPropertyGroup> ;
  sh:name "scope note"@en, "toelichting"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 34 ;
  sh:path skos:scopeNote ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-source> a sh:PropertyShape ;
  rdfs:label "bron"@nl ;
  sh:description "Relateert een begrip aan een brondocument waarvan het is afgeleid."@nl, "Relates a concept to a document from which it is derived."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#DefinitionPropertyGroup> ;
  sh:name "heeft bron"@nl, "source"@en ;
  sh:node <http://nlbegrip.nl/def/skosapnl#SourceDocument> ;
  sh:nodeKind sh:BlankNodeOrIRI ;
  sh:order 11 ;
  sh:path <http://purl.org/dc/terms/source> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#Concept-topConceptOf> a sh:PropertyShape ;
  rdfs:label "is topbegrip van"@nl ;
  sh:class skos:ConceptScheme ;
  sh:description "Relateert een begrip aan het begrippenkader waar het een top begrip van is."@nl, "Relates a concept to the concept scheme that it is a top level concept of."@en ;
  sh:group <http://nlbegrip.nl/def/skosapnl#SemanticRelationPropertyGroup> ;
  sh:name "is top concept in scheme"@en, "is topbegrip van"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 23 ;
  sh:path skos:topConceptOf ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#DefinitionPropertyGroup> a sh:PropertyGroup ;
  rdfs:label "Definitie"@nl, "Definition"@en ;
  sh:order 1 .

<http://nlbegrip.nl/def/skosapnl#Iso-thesRelationships> a sh:PropertyGroup ;
  rdfs:label "Iso-thes relaties"@nl, "Iso-thes Relationships"@en ;
  sh:order 5 .

<http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> a sh:PropertyGroup ;
  rdfs:label "Labels and Description"@en, "Termen en beschrijvingen"@nl ;
  sh:order 0 .

<http://nlbegrip.nl/def/skosapnl#MatchingRelationshipsPropertyGroup> a sh:PropertyGroup ;
  rdfs:label "Harmonisatierelaties"@nl, "Matching Relationships"@en ;
  sh:order 4 .

<http://nlbegrip.nl/def/skosapnl#NotesPropertyGroup> a sh:PropertyGroup ;
  rdfs:label "Notes"@en, "Notities"@nl ;
  sh:order 3 .

<http://nlbegrip.nl/def/skosapnl#SemanticRelationPropertyGroup> a sh:PropertyGroup ;
  rdfs:label "Semantic Relationships"@en, "Semantische relaties"@nl ;
  sh:order 2 .

<http://nlbegrip.nl/def/skosapnl#SourceDocument> a sh:NodeShape ;
  rdfs:comment "A source document is a document or web resource that is relevant for a concept"@en, "Een brondocument is een resource op het web of een fysiek document dat relevant is voor een begrip."@nl ;
  rdfs:label "Brondocument"@nl, "Source document"@en ;
  sh:property <http://nlbegrip.nl/def/skosapnl#SourceDocument-bibliographicCitation>, <http://nlbegrip.nl/def/skosapnl#SourceDocument-comment>, <http://nlbegrip.nl/def/skosapnl#SourceDocument-label>, <http://nlbegrip.nl/def/skosapnl#SourceDocument-page> ;
  sh:targetObjectsOf <http://purl.org/dc/terms/source> .

<http://nlbegrip.nl/def/skosapnl#SourceDocument-bibliographicCitation> a sh:PropertyShape ;
  rdfs:label "bronverwijzing"@nl ;
  sh:datatype xsd:string ;
  sh:description "A bibliographic reference for the resource."@en, "Een bibliografische referentie naar het brondocument."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "bibliographic citation"@en, "bronverwijzing"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 8 ;
  sh:path <http://purl.org/dc/terms/bibliographicCitation> ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#SourceDocument-comment> a sh:PropertyShape ;
  rdfs:label "uitleg"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A description of the source document in simple language, at language level B1, which can be understood without further context."@en, "Een beschrijving van het brondocument in eenvoudige taal, op taalniveau B1, die zonder verdere context begrepen kan worden."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "comment"@en, "uitleg"@nl ;
  sh:nodeKind sh:Literal ;
  sh:order 5 ;
  sh:path rdfs:comment ;
  sh:severity sh:Warning .

<http://nlbegrip.nl/def/skosapnl#SourceDocument-label> a sh:PropertyShape ;
  rdfs:label "naam"@nl ;
  sh:datatype rdf:langString ;
  sh:description "A word or phrase used to label the source document."@en, "Een naam is een voor mensen leesbare term ter aanduiding van het brondocument."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:minCount 1 ;
  sh:name "label"@en, "naam"@nl ;
  sh:order 4 ;
  sh:path <http://purl.org/dc/terms/title> ;
  sh:severity sh:Info .

<http://nlbegrip.nl/def/skosapnl#SourceDocument-page> a sh:PropertyShape ;
  rdfs:label "url"@nl ;
  sh:description "Location of the source data on the internet"@en, "Vindplaats van de bron op internet."@nl ;
  sh:group <http://nlbegrip.nl/def/skosapnl#LabelsAndDescriptionPropertyGroup> ;
  sh:name "page"@en, "url"@nl ;
  sh:nodeKind sh:IRI ;
  sh:order 7 ;
  sh:path foaf:page ;
  sh:severity sh:Warning .
