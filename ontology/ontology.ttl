@prefix schema: <https://schema.org/>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix ex: <http://example.com/>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix dash: <http://datashapes.org/dash#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix stsr: <http://ontology.shapething.com/shacl-renderer#>.
@prefix stf: <http://ontology.shapething.com/facet#>.
@prefix ed: <https://editorjs.io/>.
@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix faker: <https://fakerjs.dev/>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix app: <http://example.com/>.

stf:CountFacet a rdf:Class.
stf:DateFacet a rdf:Class.
stf:facet a rdf:Property;
    rdfs:comment "Similar to dash:editor and dash:viewer but then for facets"@en.
stf:TextFieldFacet a rdf:Property, rdf:Class, rdfs:Class;
    rdfs:comment "A textfield facet"@en.
stsr:collections a rdf:Property;
    rdfs:comment "A property that can be used inside a SHACL property shape to specify that the iconify collections can only be of the given ones."@en.
stsr:color a rdf:Property, rdfs:Datatype;
    rdfs:comment "Defines that the value is a color"@en.
stsr:ColorViewer a rdf:Class.
stsr:CommaList a rdf:Property, rdf:Class, rdfs:Class;
    rdfs:comment "A comma separated list."@en.
stsr:EditorJsEditor a rdf:Class.
stsr:endpoint a rdf:Property;
    rdfs:comment "To be used in nested SHACL nodes when the data is external."@en.
stsr:FileUploadEditor a rdf:Class.
stsr:groupLabelPath a rdf:Property.
stsr:hiddenWhen a rdf:Property.
stsr:HideWidget a rdf:Property, rdf:Class, rdfs:Class;
    rdfs:comment "Can be used for dash:viewer, dash:editor, stf:Facet or stsr:listType when no rendering is needed for that context."@en.
stsr:iconifyCollections a rdf:Property.
stsr:IconifyEditor a rdf:Class.
stsr:IconifyViewer a rdf:Class.
stsr:label a rdf:Property.
stsr:listType a rdf:Property;
    rdfs:comment "Similar to dash:editor and dash:viewer but then for lists"@en.
stsr:NaturalLanguageList a rdf:Property, rdf:Class, rdfs:Class;
    rdfs:comment "A natural language list, uses the browsers API to output a natural language list."@en.
stsr:nestedOrder a rdf:Property.
stsr:NumberFieldEditor a rdf:Class.
stsr:purpose a rdf:Property;
    rdfs:comment "The purpose of a SHACL property shape for the SHACL renderer, stsr:image or stsr:label are valid values."@en.
stsr:ShapeEditor a rdf:Class.
stsr:SubShape a rdf:Class.
stsr:UnorderedList a rdf:Property, rdf:Class, rdfs:Class;
    rdfs:comment "An unordered list."@en.
stsr:uploadUrl a rdf:Property.
ed:OutputData a rdf:Class.
faker:generator a rdf:Property.
