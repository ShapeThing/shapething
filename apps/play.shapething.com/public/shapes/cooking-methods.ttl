<http://purl.obolibrary.org/obo/FOODON_03450022> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooked in a pressure cooker."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0022";
    <http://www.geneontology.org/formats/oboInOwl#hasSynonym> "pressure-cooked"@en;
    a owl:Class;
    rdfs:label "steaming with pressure"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450021>.
<http://purl.obolibrary.org/obo/FOODON_03450023> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooked suspended above boiling water."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0023";
    a owl:Class;
    rdfs:label "steaming without pressure"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450021>.
<http://purl.obolibrary.org/obo/FOODON_03450029> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooked in hot fat or oil deep enough to immerse the food entirely."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0029";
    <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "deep-frying"@en;
    a owl:Class;
    rdfs:label "deep-frying process"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450025>.
<http://purl.obolibrary.org/obo/FOODON_03450035> <http://purl.obolibrary.org/obo/IAO_0000115> "A chinese cooking technique similar to sauteing in which thick slices or chunks of floured or battered ingredients are slow seared over moderate to low heat."@en;
    <http://purl.obolibrary.org/obo/IAO_0000119> "Kuo, The key to chinese cooking, Knopf, 1977, p.87";
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0035";
    <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "shallow frying"@en;
    a owl:Class;
    rdfs:label "shallow frying process"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450025>.
<http://purl.obolibrary.org/obo/FOODON_03450047> <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0047";
    <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "pressure frying"@en;
    a owl:Class;
    rdfs:comment "LanguaL curation note: Use when e.g. meat and cooking oil are brought to high temperatures while pressure is held high enough that the water within is prevented from boiling off."@en;
    rdfs:label "pressure frying process"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450025>.
<http://purl.obolibrary.org/obo/FOODON_03450018> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooked in boiling water at 212 degrees F. The water incorporates itself into the product being cooked or is not discarded when cooking is complete."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0018";
    a owl:Class;
    rdfs:label "boiling without draining"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450014>.
<http://purl.obolibrary.org/obo/FOODON_03450043> <http://purl.obolibrary.org/obo/IAO_0000115> "A Chinese cooking technique to prepare delicate food such as bird nests, shark fins, etc. The food is covered with water and put in a covered ceramic jar and the jar is then steamed for several hours."@en;
    <http://purl.obolibrary.org/obo/IAO_0000119> "https://en.wikipedia.org/wiki/Double_steaming";
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0043";
    <http://www.geneontology.org/formats/oboInOwl#hasSynonym> "double boiling"@en;
    a owl:Class;
    rdfs:comment "This technique ensures there is no loss of liquid or moisture (its essences) from the food being cooked, hence it is often used with expensive ingredients like Chinese herbal medicines. [Wikipedia]"@en;
    rdfs:label "double steaming"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450014>.
<http://purl.obolibrary.org/obo/FOODON_00002462> <http://purl.obolibrary.org/obo/IAO_0000115> "A form of frying characterized by the use of minimal cooking oil or fat (compared to shallow frying or deep frying); typically using just enough oil to lubricate the pan. A pan fry takes place at lower heat than does a sauté."@en;
    dct:contributor "https://orcid.org/0000-0002-8844-9165";
    a owl:Class;
    rdfs:label "shallow frying"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450026>.
<http://purl.obolibrary.org/obo/FOODON_03450027> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooking in a very small amount of very hot fat, turning and browning the food on all sides."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0027";
    <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "sauteing"@en;
    a owl:Class;
    rdfs:label "sautéing"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450026>.
<http://purl.obolibrary.org/obo/FOODON_03450028> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooked by frying foods quickly over high heat, stirring constantly. Only enough cooking oil is used to coat the bottom of the pan."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0028";
    a owl:Class;
    rdfs:label "stir-frying"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450026>.
<http://purl.obolibrary.org/obo/FOODON_03450016> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooked in boiling water at 212 degrees F. Liquid to solid ratio is greater than 2:1."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0016";
    a owl:Class;
    rdfs:label "boiling in large amount of liquid"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450015>.
<http://purl.obolibrary.org/obo/FOODON_03450017> <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0017";
    a owl:Class;
    rdfs:label "boiling in small amount of liquid"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450015>.

