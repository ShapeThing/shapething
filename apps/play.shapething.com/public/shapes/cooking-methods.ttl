    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450002>.
<http://purl.obolibrary.org/obo/FOODON_03470150> <http://purl.obolibrary.org/obo/IAO_0000115> "Sous-vide, French for \"under vacuum\", is a method of cooking that is intended to maintain the integrity of ingredients by heating them for an extended period of time in vacuum sealed plastic pouches at relatively low temperatures. Food is cooked for a long time, sometimes well over 24 hours. Unlike cooking in a slow cooker, sous-vide cooking uses airtight plastic bags placed in hot water well below boiling point (usually around 60°C or 140°F)."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=J0150";
    <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> "sous vide"@en;
    a owl:Class;
    rdfs:label "sous vide cooking"@en;
    rdfs:subClassOf <http://purl.obolibrary.org/obo/FOODON_03450002>.
<http://purl.obolibrary.org/obo/FOODON_03450010> <http://purl.obolibrary.org/obo/IAO_0000115> "Cooking with direct heat until the surface of the food is browned, usually associated with bread or sandwiches."@en;
    <http://www.geneontology.org/formats/oboInOwl#hasDbXref> "http://www.langual.org/langual_thesaurus.asp?termid=G0010";
