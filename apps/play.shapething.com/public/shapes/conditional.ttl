@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix stsr: <http://ontology.shapething.com/shacl-renderer#> .
@prefix stf: <http://ontology.shapething.com/facet#> .
@prefix ex: <http://example.org/> .

<>
  a sh:NodeShape ;
  sh:targetClass schema:Product ;

  sh:nodeKind sh:IRI ;

  sh:property [
    sh:name "Name"@en ;
    sh:path schema:name ;
    sh:defaultValue "Your product name" ;
    sh:minCount 1;
    sh:maxCount 1;
    sh:order 1 ;
    sh:datatype xsd:string ;
  ];

  sh:property [
    sh:name "Type"@en ;
    sh:path ex:type ;
    sh:maxCount 1;
    sh:order 2 ;
    sh:in (
      ex:Electronics
      ex:Furniture
      ex:Clothing
    ) ;
  ];

  sh:or (<#electronicsProducts>
         <#furnitureProducts>
         <#clothingProducts>);

  sh:property [
    sh:name "Role"@en ;
    sh:path ex:role ;
    sh:maxCount 1;
    sh:order 20 ;
    sh:in (
      ex:Role1
      ex:Role2
    ) ;
  ];

  sh:or (<#role1> <#role2>);
.

<#electronicsProducts>
  a sh:NodeShape ;
  
  sh:property [
    sh:path ex:type ;
    sh:hasValue ex:Electronics ;
  ];

  sh:property [
    sh:name "Warranty Period"@en ;
    sh:path schema:warranty ;
    sh:order 3 ;
    sh:maxCount 1;
    sh:datatype xsd:string ;
  ];
  
  sh:property [
    sh:name "Power Consumption"@en ;
    sh:path schema:powerConsumption ;
    sh:maxCount 1;
    sh:order 4 ;
    sh:datatype xsd:string ;
  ].

<#furnitureProducts>
  a sh:NodeShape ;
    
  sh:property [
    sh:path ex:type ;
    sh:hasValue ex:Furniture ;
  ];

  sh:property [
    sh:name "Material"@en ;
    sh:path schema:material ;
    sh:maxCount 1;
    sh:order 3 ;
    sh:datatype xsd:string ;
  ];
  
  sh:property [
    sh:name "Dimensions"@en ;
    sh:path schema:dimensions ;
    sh:maxCount 1;
    sh:order 4 ;
    sh:datatype xsd:string ;
  ].
  
<#clothingProducts>
  a sh:NodeShape ;
  
  sh:property [
    sh:path ex:type ;
    sh:hasValue ex:Clothing ;
  ];

  sh:property [
    sh:name "Size"@en ;
    sh:path schema:size ;
    sh:maxCount 1;
    sh:order 3 ;
    sh:datatype xsd:string ;
  ];
  
  sh:property [
    sh:name "Color"@en ;
    sh:path schema:color ;
    sh:maxCount 1;
    sh:order 4 ;
    sh:datatype xsd:string ;
  ].

ex:Electronics rdfs:label "Electronics"@en ;
  rdfs:comment "Products related to electronic devices."@en .
ex:Furniture  rdfs:label "Furniture"@en ;
  rdfs:comment "Products related to furniture."@en .  
ex:Clothing rdfs:label "Clothing"@en ;
  rdfs:comment "Products related to clothing."@en .


<#role1>
  a sh:NodeShape ;
    
  sh:property [
    sh:path ex:role ;
    sh:hasValue ex:Role1 ;
  ];

  sh:property [
    sh:name "Role 1"@en ;
    sh:path schema:roleField ;
    sh:maxCount 1;
    sh:order 21 ;
    sh:datatype xsd:string ;
  ]; 
.

<#role2>
  a sh:NodeShape ;
    
  sh:property [
    sh:path ex:role ;
    sh:hasValue ex:Role2 ;
  ];

  sh:property [
    sh:name "Role 2"@en ;
    sh:path schema:roleField ;
    sh:maxCount 1;
    sh:order 22 ;
    sh:datatype xsd:string ;
  ];  
.

ex:Role1 rdfs:label "Role 1"@en .
ex:Role2  rdfs:label "Role 2"@en .