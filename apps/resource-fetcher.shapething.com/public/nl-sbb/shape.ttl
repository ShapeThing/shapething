@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix : <https://example.org/> .

:Shape
  a sh:NodeShape ;
  sh:targetClass sh:NodeShape ;

  sh:property [
    sh:path sh:property ;

    # If an IRI is used to denote sh:node (as with :Shape), traversal is recursive.
    # The fetcher resolves that NodeShape and starts a nested resource fetch.
    # For each property value, a new CBD fetch is executed.
    # In this case, it fully fetches properties, nested sh:node values, and property groups.

    sh:node :Shape ;

    sh:property [
      sh:path [ sh:alternativePath ( 
        sh:node sh:group  
      ) ] ;
      sh:node :Shape ;
    ] ;

  ] ;
.