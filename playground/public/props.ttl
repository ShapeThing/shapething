@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix stsr: <http://ontology.shapething.com/shacl-renderer#> .
@prefix faker: <https://fakerjs.dev/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix prop: <http://ontology.shapething.com/shacl-renderer/props/> .

<>
  a sh:NodeShape, stsr:Shape ;
  sh:targetClass stsr:Props ;

  sh:property [
    sh:path rdf:type ;
    sh:hasValue stsr:Props ;
  ];

  sh:property [
    sh:name "Mode" ;
    sh:path prop:mode ;
    sh:in ( "edit" "view" "facet" ) ;
    sh:description "Do you want to show a form, display the data or show search facets?" ;
    sh:maxCount 1;
  ];

  sh:property [
    sh:name "Subject" ;
    sh:path prop:subject ;
    sh:maxCount 1;
    sh:description "The subject of the properties, a resource URI." ;
  ];

  sh:property [
    sh:name "Shape subject" ;
    sh:path prop:shapeSubject ;
    sh:maxCount 1;
    sh:description "The subject of the shape, a resource URI." ;
  ];

  sh:property [
    sh:name "Target class" ;
    sh:path prop:targetClass ;
    sh:maxCount 1;
    sh:description "The class of the target resource, a resource URI." ;
  ];

  sh:property [
    sh:name "Language mode" ;
    sh:path prop:languageMode ;
    sh:in ( "tabs" "individual" ) ;
    sh:maxCount 1;
    sh:description "How to display the language selector, either as tabs or as a dropdown." ;
  ];

  sh:property [
    sh:name "Enable subject editor" ;
    sh:path prop:enableSubjectEditor ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1;
    sh:description "Enable the subject editor, which allows editing the subject of the properties." ;
  ];

  sh:property [
    sh:name "Enable action picker" ;
    sh:path prop:enableActionPicker ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1;
    sh:description "Enable the action picker, which allows selecting actions to perform on the properties." ;
  ];

  sh:property [
    sh:name "Show extraneous predicates" ;
    sh:path prop:showExtraneousPredicates ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1;
    sh:description "Show predicates that are not defined in the shape, useful for debugging." ;
  ];
.