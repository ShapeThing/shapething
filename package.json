{
  "name": "@shapething/monorepo",
  "version": "1.0.0",
  "description": "",
  "homepage": "https://shapething.com",
  "license": "GPL-3.0-only",
  "author": "Daniel Beeke <mail@danielbeeke.nl>",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.10.3",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,ts,jsx,tsx}": "eslint --report-unused-disable-directives --no-warn-ignored --max-warnings 0"
  },
  "pnpm": {
    "patchedDependencies": {
      "@hydrofoil/shape-to-query@0.15.0": "patches/@hydrofoil__shape-to-query@0.15.0.patch"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "sharp"
    ]
  }
}
